# Layout Orchestrator — Environment Configuration
# Copy this file to .env and fill in values for your setup.

# ─── HTTP Server ──────────────────────────────────────────────────────────────
HTTP_PORT=3000
HTTP_HOST=0.0.0.0

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=layout-orchestrator
# MQTT_USERNAME=
# MQTT_PASSWORD=

# ─── DCC Serial Controller ────────────────────────────────────────────────────
DCC_SERIAL_PORT=/dev/ttyUSB0
DCC_BAUD_RATE=115200

# ─── Simulator / Hardware Mode ────────────────────────────────────────────────
#
#  USE_SIMULATOR=true,  DCC_SIMULATOR=any   → Full simulator (no broker, no hardware)
#  USE_SIMULATOR=false, DCC_SIMULATOR=true  → Hybrid: real MQTT broker + simulated DCC
#  USE_SIMULATOR=false, DCC_SIMULATOR=false → Full hardware: real broker + DCC EX serial
#
# Set USE_SIMULATOR=true only when you want to run with no broker and no hardware at all.
USE_SIMULATOR=false
DCC_SIMULATOR=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/layout.db
# Path to the Drizzle migration files. Migrations are applied automatically on startup.
MIGRATIONS_PATH=./migrations

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
